{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "Seq Scans vs Index Scans",
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_seq_scan{relname=\"pedidos\"}[1m])",
          "legendFormat": "Seq Scans"
        },
        {
          "expr": "rate(pg_stat_user_tables_idx_scan{relname=\"pedidos\"}[1m])",
          "legendFormat": "Index Scans"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Dead Tuples en pedidos",
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_dead_tup{relname=\"pedidos\"}",
          "legendFormat": "Dead Tuples"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Conexiones activas",
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"dbii_hw4\",state=\"active\"}",
          "legendFormat": "Active Connections"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Database Size",
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"dbii_hw4\"}",
          "legendFormat": "DB Size"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Insert Rate",
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_n_tup_ins{relname=\"pedidos\"}[1m])",
          "legendFormat": "Inserts/s"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Index Usage",
      "targets": [
        {
          "expr": "rate(pg_stat_user_indexes_idx_scan{relname=\"pedidos\"}[1m])",
          "legendFormat": "{{indexrelname}}"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": [],
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "title": "DBII U4 PostgreSQL Observability",
  "version": 1
}